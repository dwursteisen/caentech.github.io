---
import { getCollection } from "astro:content";

const allSpeakers = await getCollection("speakers");

const speakers = allSpeakers.map((s) => ({
  id: s.data.id,
  name: s.data.name,
  role: s.data.role,
  company: s.data.company,
  photo: s.data.photo || "/images/placeholder-avatar.svg",
}));
---

<section class="Section alt">
  <div class="Wrap">
    <h2 class="Section-title">Intervenants</h2>
    <div class="Grid cols3" id="speakers-teaser-grid" aria-live="polite"></div>
    <div class="Section-cta">
      <a href="/programme/#intervenants" class="Btn outline">Voir tous les intervenants</a>
    </div>
  </div>
</section>

<script type="application/json" id="speakers-teaser-data" set:html={JSON.stringify(speakers)} />

<script is:inline>
  (function () {
    const grid = document.getElementById("speakers-teaser-grid");
    const dataEl = document.getElementById("speakers-teaser-data");
    if (!grid || !dataEl) return;

    const speakers = JSON.parse(dataEl.textContent || "[]");
    if (speakers.length === 0) return;

    const PICK = Math.min(3, speakers.length);

    function escapeHtml(text) {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function pickRandom(n) {
      const pool = speakers.slice();
      const out = [];
      for (let i = 0; i < n && pool.length > 0; i++) {
        const idx = Math.floor(Math.random() * pool.length);
        out.push(pool.splice(idx, 1)[0]);
      }
      return out;
    }

    function render() {
      const picks = pickRandom(PICK);
      grid.innerHTML = picks
        .map((s) => {
          const roleParts = [s.role, s.company].filter(Boolean).join(" — ");
          return `
            <div class="SpeakersTeaser-item">
              <div class="SpeakersTeaser-photo">
                <img src="${escapeHtml(s.photo)}" alt="${escapeHtml(s.name)}" width="240" height="240" loading="lazy" />
              </div>
              <h3 class="SpeakersTeaser-name">${escapeHtml(s.name)}</h3>
              ${roleParts ? `<p class="SpeakersTeaser-role">${escapeHtml(roleParts)}</p>` : ""}
            </div>
          `;
        })
        .join("");
    }

    render();
    setInterval(render, 30000);
  })();
</script>

<style>
  .SpeakersTeaser-item {
    text-align: center;
  }

  .SpeakersTeaser-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto var(--space-md);
    background-color: var(--color-bg-alt);
  }

  .SpeakersTeaser-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .SpeakersTeaser-name {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .SpeakersTeaser-role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }
</style>
