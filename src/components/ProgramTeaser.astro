---
import { getCollection } from "astro:content";

const allProgram = await getCollection("program");
const allSpeakers = await getCollection("speakers");

function getSpeakers(speakerIds: string[]) {
  return speakerIds
    .map((id) => {
      const s = allSpeakers.find((sp) => sp.data.id === id);
      if (!s) return null;
      return {
        id: s.data.id,
        name: s.data.name,
        photo: s.data.photo || "/images/placeholder-avatar.svg",
      };
    })
    .filter(Boolean);
}

// Keep only real talks (exclude breaks / all-room slots)
const talks = allProgram
  .filter((p) => p.data.roomId !== "all")
  .map((p) => ({
    id: p.data.id,
    title: p.data.title,
    theme: p.data.theme,
    startTime: p.data.startTime,
    endTime: p.data.endTime,
    speakers: getSpeakers(p.data.speakerIds),
  }));
---

<section class="Section">
  <div class="Wrap">
    <h2 class="Section-title">Programme</h2>
    <p class="Section-subtitle">Quelques temps forts de la journée</p>
    <div class="Grid cols2" id="program-teaser-grid" aria-live="polite"></div>
    <div class="Section-cta">
      <a href="/programme" class="Btn outline">Voir le programme complet</a>
    </div>
  </div>
</section>

<script type="application/json" id="program-teaser-data" set:html={JSON.stringify(talks)} />

<script is:inline>
  (function () {
    const grid = document.getElementById("program-teaser-grid");
    const dataEl = document.getElementById("program-teaser-data");
    if (!grid || !dataEl) return;

    const talks = JSON.parse(dataEl.textContent || "[]");
    if (talks.length === 0) return;

    function formatTime(iso) {
      return new Date(iso).toLocaleTimeString("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function escapeHtml(text) {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function pickTwo() {
      if (talks.length <= 2) return talks.slice();
      const first = Math.floor(Math.random() * talks.length);
      let second = Math.floor(Math.random() * (talks.length - 1));
      if (second >= first) second += 1;
      return [talks[first], talks[second]];
    }

    function renderAvatars(speakers) {
      if (!speakers || speakers.length === 0) return "";
      return `
        <div class="ProgramTeaser-avatars">
          ${speakers
            .map(
              (s) =>
                `<img class="ProgramTeaser-avatar" src="${escapeHtml(s.photo)}" alt="${escapeHtml(s.name)}" title="${escapeHtml(s.name)}" width="32" height="32" loading="lazy" />`,
            )
            .join("")}
        </div>
      `;
    }

    function render() {
      const picks = pickTwo();
      grid.innerHTML = picks
        .map(
          (item) => `
            <a class="Card interactive" href="/programme#talk-${encodeURIComponent(item.id)}">
              <div class="Card-body">
                <p class="Card-meta">
                  <span class="Tag theme">${escapeHtml(item.theme)}</span>
                  <span class="Tag">${formatTime(item.startTime)} – ${formatTime(item.endTime)}</span>
                </p>
                <h3 class="Card-title">${escapeHtml(item.title)}</h3>
                ${renderAvatars(item.speakers)}
              </div>
            </a>
          `,
        )
        .join("");
    }

    render();
    setInterval(render, 30000);
  })();
</script>

<style is:global>
  #program-teaser-grid .Card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ProgramTeaser-avatars {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }

  .ProgramTeaser-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    background-color: var(--color-border);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 1px var(--color-border);
  }
</style>
