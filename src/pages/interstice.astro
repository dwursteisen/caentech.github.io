---
import { getCollection, getEntry } from "astro:content";

const allProgram = await getCollection("program");
const allSpeakers = await getCollection("speakers");
const allRooms = await getCollection("rooms");
const allSponsors = await getCollection("sponsors");
const siteEntry = await getEntry("site", "caen-tech-2026");
const site = siteEntry!.data;

function formatTime(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
}

function getSpeakerNames(ids: string[]): string {
  return ids
    .map((id) => allSpeakers.find((s) => s.id === id)?.data.name)
    .filter(Boolean)
    .join(", ");
}

const roomsById = Object.fromEntries(allRooms.map((r) => [r.id, r.data]));

const sortedProgram = [...allProgram].sort(
  (a, b) => new Date(a.data.startTime).getTime() - new Date(b.data.startTime).getTime(),
);

const tiers = [
  { key: "gold" as const, label: "Gold", color: "#d4a017" },
  { key: "silver" as const, label: "Silver", color: "#8a8a8a" },
  { key: "bronze" as const, label: "Bronze", color: "#a0522d" },
];

const programJson = JSON.stringify(
  sortedProgram.map((p) => ({
    id: p.id,
    title: p.data.title,
    speakers: getSpeakerNames(p.data.speakerIds),
    startTime: p.data.startTime,
    endTime: p.data.endTime,
    roomId: p.data.roomId,
    roomName: p.data.roomId === "all" ? "Toutes les salles" : (roomsById[p.data.roomId]?.name ?? ""),
    theme: p.data.theme,
    type: p.data.type,
  })),
);

const roomsJson = JSON.stringify(allRooms.map((r) => ({ id: r.id, name: r.data.name, color: r.data.color })));
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1920, height=1080, initial-scale=1" />
    <title>Caen.Tech — Interstice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ===== Slide 1: Programme ===== -->
    <div class="Interstice-slide" data-slide="programme">
      <div class="Interstice-diagonal"></div>
      <header class="Interstice-header">
        <div class="Interstice-logo">Caen.Tech<span>/</span></div>
        <div class="Interstice-meta">9 juin 2026 — MoHo, Caen</div>
      </header>
      <main class="Interstice-content">
        <div class="Programme-title">
          <h1>Programme<br />de la journ&eacute;e</h1>
          <div class="Programme-titleSlash"></div>
        </div>
        <div class="Programme-grid" id="programme-grid">
          <!-- Filled by JS based on ?salle param -->
        </div>
      </main>
      <footer class="Interstice-footer">
        <span class="Interstice-footerBrand">Caen.Tech</span>
        <span class="Interstice-footerSub">&copy; 2026</span>
      </footer>
    </div>

    <!-- ===== Slide 2: Sponsors ===== -->
    <div class="Interstice-slide" data-slide="sponsors">
      <div class="Interstice-diagonal"></div>
      <header class="Interstice-header">
        <div class="Interstice-logo">Caen.Tech<span>/</span></div>
        <div class="Interstice-meta">9 juin 2026 — MoHo, Caen</div>
      </header>
      <main class="Interstice-content Sponsors-content">
        <h1 class="Sponsors-title">Nos sponsors</h1>
        <div class="Sponsors-titleSlash"></div>
        {
          tiers.map(({ key, label, color }) => {
            const sponsors = allSponsors.filter((s) => s.data.tier === key);
            if (sponsors.length === 0) return null;
            return (
              <div class="Sponsors-tier">
                <h2 class="Sponsors-tierLabel" style={`color: ${color}`}>
                  {label}
                </h2>
                <div class:list={["Sponsors-tierGrid", key]}>
                  {sponsors.map((s) => (
                    <div class="Sponsors-tierItem">
                      <img src={s.data.logo} alt={s.data.name} />
                      <span>{s.data.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })
        }
      </main>
      <footer class="Interstice-footer">
        <span class="Interstice-footerBrand">Caen.Tech</span>
        <span class="Interstice-footerSub">&copy; 2026</span>
      </footer>
    </div>

    <!-- ===== Slide 3: Session courante ===== -->
    <div class="Interstice-slide" data-slide="session">
      <div class="Interstice-diagonal"></div>
      <header class="Interstice-header">
        <div class="Interstice-logo">Caen.Tech<span>/</span></div>
        <div class="Interstice-meta">9 juin 2026 — MoHo, Caen</div>
      </header>
      <main class="Interstice-content Session-content">
        <h1 class="Session-title" id="session-title">En ce moment</h1>
        <div class="Session-titleSlash"></div>
        <div class="Session-cards" id="session-cards">
          <!-- Filled by JS with current sessions -->
        </div>
        <div class="Session-empty" id="session-empty" hidden>
          <p>La journ&eacute;e est termin&eacute;e</p>
          <p class="Session-emptyHint">Merci et &agrave; l&rsquo;ann&eacute;e prochaine&nbsp;!</p>
        </div>
      </main>
      <footer class="Interstice-footer">
        <span class="Interstice-footerBrand">Caen.Tech</span>
        <span class="Interstice-footerSub">&copy; 2026</span>
      </footer>
    </div>

    <div class="Interstice-pips" id="slide-pips">
      <button class="Interstice-pip is-active" data-target="programme" aria-label="Programme"></button>
      <button class="Interstice-pip" data-target="sponsors" aria-label="Sponsors"></button>
      <button class="Interstice-pip" data-target="session" aria-label="Session courante"></button>
    </div>

    <script is:inline define:vars={{ programJson, roomsJson }}>
      const program = JSON.parse(programJson);
      const rooms = JSON.parse(roomsJson);

      const params = new URLSearchParams(window.location.search);
      const activeSalle = params.get("salle") || "room-a";

      // Compare only hours/minutes so the page works on any day
      const heureParam = params.get("heure");
      let nowMinutes;
      if (heureParam) {
        const [h, m] = heureParam.split(":").map(Number);
        nowMinutes = h * 60 + m;
      } else {
        const now = new Date();
        nowMinutes = now.getHours() * 60 + now.getMinutes();
      }

      function toMinutes(item) {
        const start = new Date(item.startTime);
        const end = new Date(item.endTime);
        return {
          startMin: start.getHours() * 60 + start.getMinutes(),
          endMin: end.getHours() * 60 + end.getMinutes(),
        };
      }

      function isBreakItem(item) {
        return item.roomId === "all" && /^pause/i.test(item.title);
      }

      function isCurrentItem(item) {
        const { startMin, endMin } = toMinutes(item);
        return nowMinutes >= startMin && nowMinutes < endMin;
      }

      function isPastItem(item) {
        const { endMin } = toMinutes(item);
        return nowMinutes >= endMin;
      }

      function isFutureItem(item) {
        const { startMin } = toMinutes(item);
        return nowMinutes < startMin;
      }

      // Keep only the last N past items + all current/future items
      function trimPastItems(items, keepPast) {
        const pastItems = items.filter((p) => isPastItem(p));
        const rest = items.filter((p) => !isPastItem(p));
        const trimmed = pastItems.slice(-keepPast);
        return trimmed.concat(rest);
      }

      // --- Programme slide ---
      function buildProgramme() {
        const grid = document.getElementById("programme-grid");
        if (!grid) return;

        const activeRoom = rooms.find((r) => r.id === activeSalle);
        const secondaryRooms = rooms.filter((r) => r.id !== activeSalle);

        const mainItems = program.filter((p) => p.roomId === activeSalle || p.roomId === "all");
        const secondaryItems = program.filter(
          (p) => p.roomId !== activeSalle && p.roomId !== "all",
        );

        const secondaryByRoom = {};
        for (const r of secondaryRooms) {
          secondaryByRoom[r.id] = secondaryItems.filter((p) => p.roomId === r.id);
        }

        let html = "";

        // Main column
        html += '<section class="Programme-main">';
        html +=
          '<div class="Programme-roomHeader">' +
          '<h2 class="Programme-roomName">' +
          (activeRoom ? activeRoom.name : "Programme") +
          "</h2>" +
          '<div class="Programme-roomLine"></div>' +
          "</div>";
        html += '<div class="Programme-items">';
        const visibleMainItems = trimPastItems(mainItems, 2);
        for (const item of visibleMainItems) {
          const time = new Date(item.startTime).toLocaleTimeString("fr-FR", {
            hour: "2-digit",
            minute: "2-digit",
          });
          const isBreak = isBreakItem(item);
          const isCurrent = !isBreak && isCurrentItem(item);
          const isPast = isPastItem(item);
          let cls = "Programme-item";
          if (isBreak) cls += " is-break";
          if (isPast) cls += " is-past";
          if (isCurrent) cls += " is-current";
          html += '<div class="' + cls + '">';
          html += '<span class="Programme-itemTime">' + time + "</span>";
          html += '<div class="Programme-itemBody">';
          html += '<h3 class="Programme-itemTitle">' + item.title + "</h3>";
          if (item.speakers) {
            html += '<p class="Programme-itemSpeakers">' + item.speakers + "</p>";
          }
          html += "</div>";
          if (item.type === "atelier") {
            html +=
              '<span class="Programme-itemTag">Atelier</span>';
          }
          html += "</div>";
        }
        html += "</div></section>";

        // Secondary columns
        html += '<div class="Programme-secondary">';
        for (const r of secondaryRooms) {
          const items = secondaryByRoom[r.id] || [];
          html += '<section class="Programme-secondaryCol">';
          html +=
            '<div class="Programme-roomHeader is-secondary">' +
            '<h2 class="Programme-roomName is-secondary">' +
            r.name +
            "</h2>" +
            '<div class="Programme-roomLine"></div>' +
            "</div>";
          html += '<div class="Programme-items is-secondary">';
          const visibleItems = trimPastItems(items, 2);
          for (const item of visibleItems) {
            const time = new Date(item.startTime).toLocaleTimeString("fr-FR", {
              hour: "2-digit",
              minute: "2-digit",
            });
            const isCurrent = isCurrentItem(item);
            const isPast = isPastItem(item);
            html += '<div class="Programme-item is-secondary' + (isPast ? " is-past" : "") + (isCurrent ? " is-current" : "") + '">';
            html += '<span class="Programme-itemTime is-secondary">' + time + "</span>";
            html += '<div class="Programme-itemBody">';
            html += '<h3 class="Programme-itemTitle is-secondary">' + item.title + "</h3>";
            if (item.speakers) {
              html += '<p class="Programme-itemSpeakers">' + item.speakers + "</p>";
            }
            html += "</div>";
            html += "</div>";
          }
          html += "</div></section>";
        }
        html += "</div>";

        grid.innerHTML = html;
      }

      // --- Session slide ---
      function buildSession() {
        const container = document.getElementById("session-cards");
        const empty = document.getElementById("session-empty");
        const title = document.getElementById("session-title");
        if (!container || !empty) return;

        function isSessionCandidate(p) {
          return !isBreakItem(p);
        }

        const roomSort = (a, b) => {
          if (a.roomId === activeSalle && b.roomId !== activeSalle) return -1;
          if (a.roomId !== activeSalle && b.roomId === activeSalle) return 1;
          return 0;
        };

        const current = program
          .filter((p) => isCurrentItem(p) && isSessionCandidate(p))
          .sort(roomSort);

        // If no current sessions, find next upcoming ones
        let items = current;
        let isUpcoming = false;
        if (items.length === 0) {
          const future = program.filter((p) => isFutureItem(p) && isSessionCandidate(p));
          if (future.length > 0) {
            const earliest = Math.min(...future.map((p) => toMinutes(p).startMin));
            items = future
              .filter((p) => toMinutes(p).startMin === earliest)
              .sort(roomSort);
            isUpcoming = true;
          }
        }

        if (title) {
          title.textContent = isUpcoming ? "Prochainement" : "En ce moment";
        }

        if (items.length === 0) {
          container.innerHTML = "";
          empty.hidden = false;
          return;
        }

        empty.hidden = true;

        let html = "";
        for (const item of items) {
          const room = rooms.find((r) => r.id === item.roomId);
          const startT = new Date(item.startTime).toLocaleTimeString("fr-FR", {
            hour: "2-digit",
            minute: "2-digit",
          });
          const endT = new Date(item.endTime).toLocaleTimeString("fr-FR", {
            hour: "2-digit",
            minute: "2-digit",
          });
          const isActive = item.roomId === activeSalle || item.roomId === "all";
          const roomLabel = item.roomId === "all" ? "Toutes les salles" : (room ? room.name : "");
          const roomColor = item.roomId === "all" ? "#1b1b1b" : (room ? room.color : "#555");

          html += '<div class="Session-card' + (isActive ? " is-active" : "") + '">';
          html += '<div class="Session-cardHeader">';
          html +=
            '<span class="Session-cardRoom" style="background:' +
            roomColor +
            '">' +
            roomLabel +
            "</span>";
          html += '<span class="Session-cardTime">' + startT + " — " + endT + "</span>";
          html += "</div>";
          html += '<h2 class="Session-cardTitle">' + item.title + "</h2>";
          if (item.speakers) {
            html += '<p class="Session-cardSpeakers">' + item.speakers + "</p>";
          }
          if (item.type === "atelier") {
            html += '<span class="Session-cardTag">Atelier</span>';
          }
          html += "</div>";
        }
        container.innerHTML = html;
      }

      // --- Slide rotation ---
      const slides = document.querySelectorAll(".Interstice-slide");
      const pips = document.querySelectorAll(".Interstice-pip");
      let currentIndex = 0;
      const INTERVAL = 10000; // 10s per slide

      function showSlide(index) {
        slides.forEach((s, i) => {
          if (i === index) {
            s.classList.add("is-entering");
            s.classList.remove("is-leaving", "is-hidden");
          } else if (s.classList.contains("is-entering") || (!s.classList.contains("is-hidden"))) {
            s.classList.add("is-leaving");
            s.classList.remove("is-entering");
            s.addEventListener(
              "animationend",
              () => {
                s.classList.add("is-hidden");
                s.classList.remove("is-leaving");
              },
              { once: true },
            );
          }
        });
        pips.forEach((p, i) => p.classList.toggle("is-active", i === index));
      }

      function nextSlide() {
        currentIndex = (currentIndex + 1) % slides.length;
        showSlide(currentIndex);
      }

      // Init
      buildProgramme();
      buildSession();

      slides.forEach((s, i) => {
        if (i !== 0) s.classList.add("is-hidden");
        else s.classList.add("is-entering");
      });

      let timer = setInterval(nextSlide, INTERVAL);

      // Manual pip click
      pips.forEach((pip, i) => {
        pip.addEventListener("click", () => {
          clearInterval(timer);
          currentIndex = i;
          showSlide(i);
          timer = setInterval(nextSlide, INTERVAL);
        });
      });
    </script>

    <style is:global>
      /* === Base === */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        font-family: "Outfit", system-ui, sans-serif;
        background: #000;
        color: #fff;
        -webkit-font-smoothing: antialiased;
      }

      /* === Slide shell === */
      .Interstice-slide {
        position: absolute;
        inset: 0;
        width: 1920px;
        height: 1080px;
        background: #f9f9f9;
        color: #1b1b1b;
        display: flex;
        flex-direction: column;
        opacity: 1;
      }

      .Interstice-slide.is-hidden {
        opacity: 0;
        pointer-events: none;
      }

      .Interstice-slide.is-entering {
        animation: fadeIn 0.6s ease-out forwards;
      }

      .Interstice-slide.is-leaving {
        animation: fadeOut 0.6s ease-in forwards;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes fadeOut {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
        }
      }

      /* === Diagonal accent === */
      .Interstice-diagonal {
        position: absolute;
        inset: 0;
        width: 45%;
        height: 100%;
        background: #ffd600;
        clip-path: polygon(0 0, 100% 0, 0 100%);
        z-index: 0;
      }

      /* === Header === */
      .Interstice-header {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 40px 64px;
      }

      .Interstice-logo {
        font-size: 1.8rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        text-transform: uppercase;
        color: #1b1b1b;
      }

      .Interstice-logo span {
        color: #ffd600;
        font-weight: 900;
      }

      .Interstice-meta {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(27, 27, 27, 0.5);
      }

      /* === Footer === */
      .Interstice-footer {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
        padding: 32px 64px;
        margin-top: auto;
      }

      .Interstice-footerBrand {
        font-size: 0.65rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #6d5e00;
      }

      .Interstice-footerSub {
        font-size: 0.65rem;
        color: rgba(27, 27, 27, 0.2);
      }

      /* === Pips === */
      .Interstice-pips {
        position: fixed;
        bottom: 40px;
        left: 64px;
        z-index: 100;
        display: flex;
        gap: 10px;
      }

      .Interstice-pip {
        width: 32px;
        height: 4px;
        border: none;
        border-radius: 2px;
        background: rgba(27, 27, 27, 0.15);
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .Interstice-pip.is-active {
        width: 56px;
        background: #ffd600;
      }

      /* === Content area === */
      .Interstice-content {
        position: relative;
        z-index: 10;
        flex: 1;
        padding: 0 64px;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }

      /* =========================
         SLIDE 1: PROGRAMME
         ========================= */

      .Programme-title {
        display: flex;
        align-items: flex-end;
        gap: 24px;
        margin-bottom: 48px;
      }

      .Programme-title h1 {
        font-size: 4rem;
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: -0.03em;
        text-transform: uppercase;
      }

      .Programme-titleSlash {
        height: 16px;
        width: 180px;
        background: #ffd600;
        transform: skewX(-12deg);
        margin-bottom: 8px;
      }

      .Programme-grid {
        display: flex;
        gap: 64px;
        flex: 1;
        min-height: 0;
      }

      /* Main room column */
      .Programme-main {
        flex: 7;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }

      .Programme-roomHeader {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
      }

      .Programme-roomName {
        font-size: 1.6rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        white-space: nowrap;
      }

      .Programme-roomName.is-secondary {
        font-size: 1.1rem;
        font-weight: 700;
        color: rgba(27, 27, 27, 0.6);
      }

      .Programme-roomLine {
        height: 2px;
        flex: 1;
        background: rgba(27, 27, 27, 0.08);
      }

      .Programme-roomHeader.is-secondary .Programme-roomLine {
        height: 1px;
        background: rgba(27, 27, 27, 0.05);
      }

      .Programme-items {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .Programme-item {
        display: flex;
        align-items: center;
        gap: 32px;
        padding: 20px 24px;
        border-radius: 12px;
        transition: background 0.2s;
      }

      .Programme-item.is-past {
        padding-top: 4px;
        padding-bottom: 4px;
        opacity: 0.3;
      }

      .Programme-item.is-past .Programme-itemSpeakers {
        display: none;
      }

      .Programme-item.is-current {
        background: #ffd600;
        border-radius: 12px;
        border: 2px solid #1b1b1b;
      }

      .Programme-item.is-current .Programme-itemTime {
        color: rgba(27, 27, 27, 0.6);
      }

      .Programme-item.is-break {
        background: rgba(27, 27, 27, 0.04);
        color: rgba(27, 27, 27, 0.5);
      }

      .Programme-item.is-break .Programme-itemTitle {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.95rem;
      }

      .Programme-itemTime {
        font-size: 1.3rem;
        font-weight: 700;
        color: rgba(27, 27, 27, 0.35);
        min-width: 80px;
      }

      .Programme-itemBody {
        flex: 1;
      }

      .Programme-itemTitle {
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.3;
      }

      .Programme-itemTitle.is-secondary {
        font-size: 1rem;
        font-weight: 700;
      }

      .Programme-itemSpeakers {
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(27, 27, 27, 0.5);
        margin-top: 2px;
      }

      .Programme-itemTag {
        font-size: 0.6rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 4px 12px;
        border-radius: 999px;
        background: #1b1b1b;
        color: #ffd600;
        white-space: nowrap;
      }

      .Programme-item.is-secondary {
        padding: 12px 16px;
        gap: 16px;
      }

      .Programme-itemTime.is-secondary {
        font-size: 1rem;
        min-width: 60px;
        color: rgba(27, 27, 27, 0.25);
      }

      /* Secondary rooms */
      .Programme-secondary {
        flex: 5;
        display: flex;
        flex-direction: column;
        gap: 40px;
        border-left: 1px solid rgba(27, 27, 27, 0.05);
        padding-left: 64px;
      }

      .Programme-secondaryCol {
        display: flex;
        flex-direction: column;
      }

      .Programme-items.is-secondary {
        gap: 4px;
      }

      /* =========================
         SLIDE 2: SPONSORS
         ========================= */

      .Sponsors-content {
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 48px;
      }

