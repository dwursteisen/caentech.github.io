---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPartners = await getCollection("partners");
const allTeam = await getCollection("team");
---

<BaseLayout
  title="À propos — Caen.Tech 2026"
  description="Découvrez l'histoire, l'équipe et les valeurs de Caen.Tech."
>
  <section class="Section">
    <div class="Wrap">
      <h1>À propos</h1>
    </div>
  </section>

  <section class="Section alt">
    <div class="Wrap medium">
      <h2 class="Section-title">La raison d'être de Caen.Tech</h2>
      <div class="AboutText">
        <p>
          <strong>Caen.Tech</strong> est née d'un constat simple : l'écosystème tech
          caennais est riche, dynamique, mais il manquait un rendez-vous pour le rassembler.
        </p>
        <p>
          Nos valeurs sont <strong>local, concret, humain</strong>. Pas de
          grandes promesses ni de discours hors-sol — des retours d'expérience
          par des gens qui font, ici, au quotidien.
        </p>
        <p>
          Ce n'est pas un salon commercial, ni une conférence réservée aux
          experts. C'est un espace ouvert à toutes et tous ceux qui participent
          à la tech en Normandie : développeuses, designers, POs, ops,
          entrepreneurs, étudiants, reconvertis.
        </p>
        <p>
          Notre vision : un événement annuel, des rencontres informelles et
          régulières, un podcast qui vit toute l'année, et une communauté locale
          qui grandit ensemble.
        </p>
      </div>
    </div>
  </section>

  <section class="Section" id="partenaires">
    <div class="Wrap">
      <h2 class="Section-title">Nos partenaires</h2>
      <div class="Grid cols2">
        {
          allPartners.map((partner) => (
            <div class="Card">
              <div class="Card-body Partners-cardBody">
                <a
                  href={partner.data.url}
                  target="_blank"
                  class="Partners-logo"
                >
                  <img
                    src={partner.data.logo}
                    alt={partner.data.name}
                    width="160"
                    height="48"
                    loading="lazy"
                  />
                </a>
                <div>
                  <h3 class="Card-title">
                    <a href={partner.data.url} target="_blank">
                      {partner.data.name}
                    </a>
                  </h3>
                  <p class="Card-text">{partner.data.description}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="Section alt" id="equipe">
    <div class="Wrap">
      <h2 class="Section-title">L'équipe</h2>
      <div class="Grid cols5">
        {
          allTeam.map((member) => (
            <div class="TeamMember">
              <div class="TeamMember-photo">
                <img
                  src={member.data.photo || "/images/placeholder-avatar.svg"}
                  alt={member.data.name}
                  width="240"
                  height="240"
                  loading="lazy"
                />
              </div>
              <h3 class="TeamMember-name">
                {member.data.contact ? (
                  <a href={member.data.contact} target="_blank">
                    {member.data.name}
                  </a>
                ) : (
                  member.data.name
                )}
              </h3>
              {member.data.volunteer && <span class="Tag">Bénévole</span>}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <style>
    .Partners-cardBody {
      display: flex;
      gap: var(--space-md);
      align-items: center;
    }

    .Partners-logo {
      flex-shrink: 0;
      text-decoration: none;
    }

    .AboutText p {
      margin-bottom: var(--space-md);
      line-height: 1.8;
      color: var(--color-text-light);
    }

    :global(.Grid.cols5) {
      grid-template-columns: repeat(5, 1fr);
    }

    @media (max-width: 768px) {
      :global(.Grid.cols5) {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .TeamMember {
      text-align: center;
    }

    .TeamMember-photo {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto var(--space-md);
      background-color: var(--color-bg);
    }

    .TeamMember-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .TeamMember-name {
      font-size: var(--text-base);
      font-weight: 600;
      margin-bottom: var(--space-xs);
    }
  </style>
</BaseLayout>
